# Base URL của API Express (không có dấu / ở cuối).
# Sau khi đổi file này (hoặc copy thành .env), cần khởi động lại Expo: npx expo start -c

# Máy dev / iOS Simulator / Expo Web (API chạy trên cùng máy):
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000

# --- Chọn MỘT trong các cách sau nếu 127.0.0.1 không kết nối được ---

# Android Emulator: 127.0.0.1 trong emulator là chính emulator, không phải máy host.
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Điện thoại thật (Expo Go): dùng IP LAN của máy tính chạy backend (ipconfig / ifconfig).
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3000
