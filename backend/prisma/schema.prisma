generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  locked
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum WorkoutSessionStatus {
  in_progress
  completed
}

enum ReminderType {
  workout
  water
  meal
  sleep
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  profile          UserProfile?
  goals            UserGoal[]
  refreshTokens    RefreshToken[]
  workoutPlans     WorkoutPlan[]
  workoutSessions  WorkoutSession[]
  mealLogs         MealLog[]
  bodyMetricLogs   BodyMetricLog[]
  customFoods      FoodCatalog[]
  dailyProgress    DailyProgress[]
  reminders        Reminder[]
  deviceTokens     DeviceToken[]

  @@map("users")
}

model DailyProgress {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  date                DateTime @db.Date
  totalKcalIn         Int      @map("total_kcal_in")
  totalKcalOut        Int      @default(0) @map("total_kcal_out")
  totalWorkoutMinutes Int      @default(0) @map("total_workout_minutes")
  proteinG            Decimal  @map("protein_g") @db.Decimal(10, 2)
  carbG               Decimal  @map("carb_g") @db.Decimal(10, 2)
  fatG                Decimal  @map("fat_g") @db.Decimal(10, 2)
  goalScore           Int?     @map("goal_score")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_progress")
}

model Reminder {
  id              Int          @id @default(autoincrement())
  userId          Int          @map("user_id")
  type            ReminderType
  title           String       @db.VarChar(255)
  message         String?      @db.VarChar(512)
  cronExpr        String?      @map("cron_expr") @db.VarChar(128)
  timezone        String       @db.VarChar(64)
  localHour       Int          @map("local_hour")
  localMinute     Int          @map("local_minute")
  isEnabled       Boolean      @default(true) @map("is_enabled")
  nextTriggerAt   DateTime?    @map("next_trigger_at")
  lastTriggeredAt DateTime?    @map("last_triggered_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isEnabled, nextTriggerAt])
  @@map("reminders")
}

model DeviceToken {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  platform      String   @db.VarChar(32)
  expoPushToken String   @unique @map("expo_push_token") @db.VarChar(512)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model ExerciseCatalog {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  muscleGroup String? @map("muscle_group") @db.VarChar(128)
  equipment   String? @db.VarChar(128)
  met         Decimal? @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at")

  planExercises WorkoutPlanExercise[]
  sessionSets   WorkoutSessionSet[]

  @@map("exercise_catalog")
}

model WorkoutPlan {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  name        String  @db.VarChar(255)
  description String? @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutPlanExercise[]
  sessions  WorkoutSession[]

  @@index([userId])
  @@map("workout_plans")
}

model WorkoutPlanExercise {
  id             Int      @id @default(autoincrement())
  planId         Int      @map("plan_id")
  exerciseId     Int      @map("exercise_id")
  sortOrder      Int      @map("sort_order")
  targetSets     Int?     @map("target_sets")
  targetReps     Int?     @map("target_reps")
  targetWeightKg Decimal? @map("target_weight_kg") @db.Decimal(8, 2)
  restSec        Int?     @map("rest_sec")

  plan     WorkoutPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercise ExerciseCatalog @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([planId])
  @@map("workout_plan_exercises")
}

model WorkoutSession {
  id          Int                  @id @default(autoincrement())
  userId      Int                  @map("user_id")
  planId      Int?                 @map("plan_id")
  sessionDate DateTime             @map("session_date") @db.Date
  startedAt   DateTime             @map("started_at")
  endedAt     DateTime?            @map("ended_at")
  status      WorkoutSessionStatus @default(in_progress)
  notes       String?              @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan  WorkoutPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  sets  WorkoutSessionSet[]

  @@index([userId, sessionDate])
  @@map("workout_sessions")
}

model WorkoutSessionSet {
  id                Int      @id @default(autoincrement())
  sessionId         Int      @map("session_id")
  exerciseId        Int      @map("exercise_id")
  setIndex          Int      @map("set_index")
  actualReps        Int?     @map("actual_reps")
  actualWeightKg    Decimal? @map("actual_weight_kg") @db.Decimal(8, 2)
  actualDurationSec Int?     @map("actual_duration_sec")
  rpe               Int?

  createdAt DateTime @default(now()) @map("created_at")

  session  WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise ExerciseCatalog @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@map("workout_session_sets")
}

model FoodCatalog {
  id             Int     @id @default(autoincrement())
  userId         Int?    @map("user_id")
  name           String  @db.VarChar(255)
  kcalPerServing Int     @map("kcal_per_serving")
  proteinG       Decimal @map("protein_g") @db.Decimal(8, 2)
  carbG          Decimal @map("carb_g") @db.Decimal(8, 2)
  fatG           Decimal @map("fat_g") @db.Decimal(8, 2)
  servingUnit    String? @map("serving_unit") @db.VarChar(64)

  createdAt DateTime @default(now()) @map("created_at")

  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealItems MealLogItem[]

  @@index([userId])
  @@index([name])
  @@map("food_catalog")
}

model MealLog {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  mealType MealType @map("meal_type")
  loggedAt DateTime @map("logged_at")
  notes    String?  @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealLogItem[]

  @@index([userId, loggedAt])
  @@map("meal_logs")
}

model MealLogItem {
  id             Int     @id @default(autoincrement())
  mealLogId      Int     @map("meal_log_id")
  foodId         Int?    @map("food_id")
  customFoodName String? @map("custom_food_name") @db.VarChar(255)
  quantity       Decimal @db.Decimal(10, 3)
  unit           String? @db.VarChar(64)
  kcal           Int
  proteinG       Decimal @map("protein_g") @db.Decimal(8, 2)
  carbG          Decimal @map("carb_g") @db.Decimal(8, 2)
  fatG           Decimal @map("fat_g") @db.Decimal(8, 2)

  createdAt DateTime @default(now()) @map("created_at")

  mealLog MealLog      @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
  food    FoodCatalog? @relation(fields: [foodId], references: [id], onDelete: SetNull)

  @@index([mealLogId])
  @@map("meal_log_items")
}

model BodyMetricLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  recordedAt DateTime @map("recorded_at")
  weightKg   Decimal? @map("weight_kg") @db.Decimal(6, 2)
  bodyFatPct Decimal? @map("body_fat_pct") @db.Decimal(5, 2)
  waistCm    Decimal? @map("waist_cm") @db.Decimal(6, 2)
  notes      String?  @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@map("body_metric_logs")
}

model UserProfile {
  userId        Int       @id @map("user_id")
  fullName      String?   @map("full_name") @db.VarChar(255)
  gender        String?   @db.VarChar(32)
  dob           DateTime? @db.Date
  heightCm      Decimal?  @map("height_cm") @db.Decimal(6, 2)
  activityLevel String?   @map("activity_level") @db.VarChar(64)
  timezone      String?   @db.VarChar(64)
  locale        String?   @db.VarChar(16)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserGoal {
  id                  Int       @id @default(autoincrement())
  userId              Int       @map("user_id")
  goalType            String    @map("goal_type") @db.VarChar(32)
  targetWeightKg      Decimal?  @map("target_weight_kg") @db.Decimal(6, 2)
  weeklyWorkoutTarget Int?      @map("weekly_workout_target")
  dailyKcalTarget     Int?      @map("daily_kcal_target")
  startDate           DateTime? @map("start_date") @db.Date
  targetDate          DateTime? @map("target_date") @db.Date
  isActive            Boolean   @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_goals")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
